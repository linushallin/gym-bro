generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  LEGS
  ABS
}

model Exercise {
  id          String         @id @default(cuid())
  name        String
  muscleGroup MuscleGroup
  createdAt   DateTime       @default(now())
  entries     SessionEntry[]

  @@unique([name, muscleGroup])
}

// One gym visit: you pick one or more muscle groups to start a Session, and
// every exercise logged afterwards is grouped under it until you're done.
model Session {
  id           String         @id @default(cuid())
  muscleGroups MuscleGroup[]
  notes        String?
  createdAt    DateTime       @default(now())
  finishedAt   DateTime?
  entries      SessionEntry[]

  @@index([createdAt])
}

// One exercise performed within a Session, holding its own sets.
model SessionEntry {
  id         String       @id @default(cuid())
  sessionId  String
  session    Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  sets       WorkoutSet[]

  @@index([sessionId])
  @@index([exerciseId, createdAt])
}

model WorkoutSet {
  id             String       @id @default(cuid())
  weight         Float
  reps           Int
  sessionEntryId String
  sessionEntry   SessionEntry @relation(fields: [sessionEntryId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([sessionEntryId])
}

model BodyWeight {
  id        String   @id @default(cuid())
  weight    Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}
