generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workout {
  id        String       @id @default(cuid())
  exercise  String
  createdAt DateTime     @default(now())
  sets      WorkoutSet[]
}

model WorkoutSet {
  id        String   @id @default(cuid())
  weight    Int
  reps      Int

  workoutId String
  workout   Workout  @relation(fields: [workoutId], references: [id])

  createdAt DateTime @default(now())
}
